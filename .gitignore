# Ignorar arquivos ocultos de IDEs e editores
.vscode/
.idea/
.trae/
*.suo
*.ntvs
*.njsproj
*.sln
*.sw?

# Ignorar arquivos do sistema operacional
.DS_Store
Thumbs.db

# Ignorar PDFs, documentos desnecessários e scripts temporários
*.pdf
text.txt
read_pdf.py

# Ignorar arquivos de cobertura de testes (se houver)
coverage/

